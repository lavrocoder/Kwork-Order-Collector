{
  "manifest_version": 3,
  "name": "Kwork Order Collector",
  "version": "1.0",
  "description": "Сбор переписки и данных по завершённым заказам Kwork в формате raw.md",
  "permissions": [],
  "host_permissions": [
    "https://kwork.ru/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://kwork.ru/track*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kwork Order Collector",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
